@page
@model LoginModel
@{
    ViewData["Title"] = "Logowanie";
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-8 col-lg-5">

        <div class="text-center mb-4">
            <h1 class="fw-bold display-6">Witaj ponownie!</h1>
            <p class="text-muted">Zaloguj się, aby uzyskać dostęp do swojego pulpitu.</p>
        </div>

        <div class="card shadow-sm border-0 rounded-4 p-4 p-md-5 bg-white">
            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                <div class="mb-4">
                    <label asp-for="Input.Email" class="form-label fw-semibold text-muted">Adres Email</label>
                    <input asp-for="Input.Email" class="form-control form-control-lg rounded-3 bg-light border-0" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Input.Password" class="form-label fw-semibold text-muted">Hasło</label>
                    <input asp-for="Input.Password" class="form-control form-control-lg rounded-3 bg-light border-0" autocomplete="current-password" aria-required="true" placeholder="Twoje hasło" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label class="form-check-label text-muted" asp-for="Input.RememberMe">
                            Zapamiętaj mnie
                        </label>
                    </div>
                    <a id="forgot-password" asp-page="./ForgotPassword" class="text-primary text-decoration-none small">Zapomniałeś hasła?</a>
                </div>

                <button id="login-submit" type="submit" class="btn btn-primary btn-lg rounded-pill w-100 shadow-sm">
                    Zaloguj się
                </button>
            </form>
        </div>

        <div class="text-center mt-4">
            <p class="text-muted">Nie masz jeszcze konta? <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-primary fw-semibold text-decoration-none">Zarejestruj się</a></p>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
@page
@model RegisterModel
@{
    ViewData["Title"] = "Rejestracja";
}

<div class="row justify-content-center mt-5 mb-5">
    <div class="col-md-8 col-lg-5">

        <div class="text-center mb-4">
            <h1 class="fw-bold display-6">Załóż konto</h1>
            <p class="text-muted">Dołącz do nas i zacznij kontrolować swoje wydatki.</p>
        </div>

        <div class="card shadow-sm border-0 rounded-4 p-4 p-md-5 bg-white">
            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                <div class="mb-4">
                    <label asp-for="Input.Email" class="form-label fw-semibold text-muted">Adres Email</label>
                    <input asp-for="Input.Email" class="form-control form-control-lg rounded-3 bg-light border-0" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Input.Password" class="form-label fw-semibold text-muted">Hasło</label>
                    <input asp-for="Input.Password" class="form-control form-control-lg rounded-3 bg-light border-0" autocomplete="new-password" aria-required="true" placeholder="Min. 6 znaków" />
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Input.ConfirmPassword" class="form-label fw-semibold text-muted">Potwierdź hasło</label>
                    <input asp-for="Input.ConfirmPassword" class="form-control form-control-lg rounded-3 bg-light border-0" autocomplete="new-password" aria-required="true" placeholder="Wpisz hasło ponownie" />
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>

                <button id="registerSubmit" type="submit" class="btn btn-primary btn-lg rounded-pill w-100 shadow-sm mt-3">
                    Zarejestruj się
                </button>
            </form>
        </div>

        <div class="text-center mt-4">
            <p class="text-muted">Masz już konto? <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="text-primary fw-semibold text-decoration-none">Zaloguj się</a></p>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
@model ExpenseTracker.Models.Expense

@{
    ViewData["Title"] = "Edytuj wydatek";
}

<div class="row justify-content-center mt-4 mb-5">
    <div class="col-md-8 col-lg-6">

        <h2 class="fw-bold mb-4 display-6 text-center">Edytuj wydatek</h2>

        <div class="card shadow-sm border-0 rounded-4 p-4 p-md-5">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="Id" />

                <div class="row g-4">
                    <div class="col-md-6">
                        <label asp-for="Date" class="form-label fw-semibold text-muted">Data</label>
                        <input asp-for="Date" type="date" class="form-control form-control-lg rounded-3 bg-light border-0" />
                        <span asp-validation-for="Date" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Amount" class="form-label fw-semibold text-muted">Kwota (zł)</label>
                        <input asp-for="Amount" type="number" step="0.01" class="form-control form-control-lg rounded-3 bg-light border-0" placeholder="0,00" />
                        <span asp-validation-for="Amount" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Category" class="form-label fw-semibold text-muted">Kategoria</label>
                        <input asp-for="Category" class="form-control form-control-lg rounded-3 bg-light border-0" placeholder="np. Jedzenie" />
                        <span asp-validation-for="Category" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="SubCategory" class="form-label fw-semibold text-muted">Podkategoria</label>
                        <input asp-for="SubCategory" class="form-control form-control-lg rounded-3 bg-light border-0" placeholder="np. Nabiał" />
                        <span asp-validation-for="SubCategory" class="text-danger small"></span>
                    </div>

                    <div class="col-12">
                        <label asp-for="Description" class="form-label fw-semibold text-muted">Krótki opis</label>
                        <textarea asp-for="Description" class="form-control form-control-lg rounded-3 bg-light border-0" rows="3" placeholder="Opcjonalnie..."></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="col-12 mt-5 d-flex gap-3">
                        <a asp-action="Index" class="btn btn-light btn-lg rounded-pill px-4 flex-grow-1">Anuluj</a>
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill px-4 flex-grow-1 shadow-sm">Zapisz zmiany</button>
                    </div>
                </div>
            </form>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
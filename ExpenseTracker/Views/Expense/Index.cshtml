@model IEnumerable<ExpenseTracker.Models.Expense>

@{
    ViewData["Title"] = "Expenses";
}

<div class="row justify-content-center mt-4 mb-5">
    <div class="col-12 col-xxl-10">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0 display-6">Expenses</h2>
            <a asp-action="Create" class="btn btn-primary btn-lg rounded-pill px-4 shadow-sm">
                + Dodaj nowy wydatek
            </a>
        </div>

        <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle fs-5">
                    <thead class="table-light text-muted">
                        <tr>
                            <th class="ps-4 fw-semibold border-0 py-4">Data</th>
                            <th class="fw-semibold border-0 py-4">Kategoria</th>
                            <th class="fw-semibold border-0 py-4">Podkategoria</th>
                            <th class="fw-semibold border-0 py-4">Opis</th>
                            <th class="text-end fw-semibold border-0 py-4">Kwota</th>
                            <th class="text-center pe-4 fw-semibold border-0 py-4">Akcje</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    Brak wydatków. Dodaj swój pierwszy wydatek!
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 py-4 text-secondary">@item.Date.ToShortDateString()</td>
                                    <td class="py-4">
                                        <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill fs-6">
                                            @item.Category
                                        </span>
                                    </td>
                                    <td class="py-4 text-muted">
                                        @item.SubCategory
                                    </td>
                                    <td class="text-muted py-4">@item.Description</td>
                                    <td class="text-end fw-bold text-dark py-4 fs-4">
                                        @item.Amount.ToString("C")
                                    </td>
                                    <td class="text-center pe-4 py-4">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary border-0 rounded-pill px-4">
                                            Edytuj
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Czy na pewno chcesz usunąć ten wydatek?');">
                                            <button type="submit" class="btn btn-outline-danger border-0 rounded-pill px-4">
                                                Usuń
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>
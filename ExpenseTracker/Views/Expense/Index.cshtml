@model IEnumerable<ExpenseTracker.Models.Expense>

@{
    ViewData["Title"] = "Lista Wydatków";
}

<div class="text-center mb-4">
    <h1 class="display-4">Moje Wydatki</h1>
</div>

<a href="/Expense/Create" class="btn btn-primary mb-3">Dodaj nowy wydatek</a>

<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>ID</th>
            <th>Data</th>
            <th>Kategoria</th>
            <th>Opis</th>
            <th>Kwota</th>
            <th>Akcje</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Date.ToShortDateString()</td>
                <td>@item.Category</td>
                <td>@item.Description</td>
                <td>@item.Amount zł</td>
                <td>
                    <button onclick="deleteExpense(@item.Id)" class="btn btn-danger btn-sm">Usuń</button>
                </td>
            </tr>
        }
    </tbody>
</table>
@section Scripts {
    <script>
        function deleteExpense(id) {
            // Wbudowane w przeglądarkę okienko potwierdzenia usuwania
            if (confirm("Czy na pewno chcesz usunąć ten wydatek?")) {

                // Fetch API wysyła żądanie o typie DELETE do naszego kontrolera
                fetch(`/Expense/Delete/${id}`, {
                    method: 'DELETE'
                })
                .then(response => {
                    if (response.ok) {
                        // Jeśli kontroler zwrócił "Ok()", odświeżamy stronę, by pokazać aktualną tabelę
                        window.location.reload();
                    } else {
                        alert("Wystąpił błąd podczas usuwania.");
                    }
                });
            }
        }
    </script>
}